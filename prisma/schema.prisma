// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id                   String   @id @default(cuid())
  externalId           String   @unique
  email                String   @unique
  fullName             String?
  role                 String   @default("user")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  headOf               Organization?        @relation("CompanyHead")
  memberships          OrganizationMember[]
  apiKeys              APIKey[]
  kycRecords           KYCRecord[]
  kyiRecords           KYIRecord[]
  clientMemberships    ClientMember[]
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  domain    String?
  headId    String   @unique
  head      User     @relation("CompanyHead", fields: [headId], references: [id])
  members   OrganizationMember[]
  apiKeys   APIKey[]
  kycRecords KYCRecord[]
  kyiRecords KYIRecord[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrganizationMember {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  role           String       @default("member")
  joinedAt       DateTime     @default(now())
  user           User         @relation(fields: [userId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])
  @@unique([userId, organizationId])
}

model APIKey {
  id             String       @id @default(cuid())
  name           String
  key            String       @unique
  userId         String
  organizationId String
  revoked        Boolean      @default(false)
  createdAt      DateTime     @default(now())
  user           User         @relation(fields: [userId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])
}

model KYCRecord {
  id                    String        @id @default(cuid())
  reference             String        @unique
  userId                String
  organizationId        String?
  status                String        @default("pending")
  documentType          String
  documentFrontUrl      String?
  documentBackUrl       String?
  selfieUrl             String?
  extractedData         Json?
  verificationResult    Json?
  shuftiEventType       String?
  shuftiVerificationUrl String?
  declineReason         String?
  reviewNotes           String?
  invitationToken       String?
  submittedAt           DateTime?
  reviewedAt            DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  user                  User          @relation(fields: [userId], references: [id])
  organization          Organization? @relation(fields: [organizationId], references: [id])
}

model KYCInvitation {
  id        String   @id @default(cuid())
  email     String
  name      String?
  token     String   @unique @default(cuid())
  status    String   @default("pending")
  invitedBy String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model KYIRecord {
  id                    String        @id @default(cuid())
  reference             String        @unique
  userId                String
  organizationId        String?
  status                String        @default("pending")
  isPEP                 Boolean       @default(false)
  accreditationStatus   String?
  investorType          String?
  investmentAmount      String?
  investmentCurrency    String?
  sourceOfFunds         String?
  governmentIdType      String?
  governmentIdUrl       String?
  selfieUrl             String?
  bankStatementUrl      String?
  proofOfAddressUrl     String?
  proofOfNetWorthUrl    String?
  accreditationLetterUrl String?
  sourceOfFundsDocUrl   String?
  corporateDocUrl       String?
  extractedData         Json?
  verificationResult    Json?
  riskScore             Int?
  shuftiEventType       String?
  shuftiVerificationUrl String?
  declineReason         String?
  reviewNotes           String?
  invitationToken       String?
  submittedAt           DateTime?
  reviewedAt            DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  user                  User          @relation(fields: [userId], references: [id])
  organization          Organization? @relation(fields: [organizationId], references: [id])
}

model KYIInvitation {
  id           String   @id @default(cuid())
  email        String
  investorName String?
  token        String   @unique @default(cuid())
  status       String   @default("pending")
  invitedBy    String
  expiresAt    DateTime
  createdAt    DateTime @default(now())
}

// ── Client Organisation ──────────────────────────────────
model ClientOrganization {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  domain          String?
  plan            String   @default("starter")
  scanCredits     Int      @default(0)
  scanCreditsUsed Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  members         ClientMember[]
  apiKeys         ClientAPIKey[]
  webhooks        ClientWebhook[]
  verifications   Verification[]
  auditLogs       AuditLog[]
  reports         Report[]
  alerts          AlertRule[]
}

// ── Client Team Member ───────────────────────────────────
model ClientMember {
  id             String             @id @default(cuid())
  orgId          String
  userId         String
  role           ClientRole
  isActive       Boolean            @default(true)
  invitedBy      String?
  lastLoginAt    DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  org            ClientOrganization @relation(fields: [orgId], references: [id])
  user           User               @relation(fields: [userId], references: [id])
  @@unique([orgId, userId])
}

enum ClientRole {
  CLIENT_ADMIN
  COMPLIANCE_ANALYST
  DEVELOPER
  VIEWER
}

// ── Verification Case ────────────────────────────────────
model Verification {
  id              String             @id @default(cuid())
  caseId          String             @unique @default(cuid())
  orgId           String
  type            VerificationType
  status          VerificationStatus @default(STARTED)
  subjectName     String?
  subjectRef      String?
  assignedTo      String?
  sentinelScore   Float?
  sentinelOutcome SentinelOutcome?
  documents       Json?
  flags           Json?
  metadata        Json?
  reviewedBy      String?
  reviewNotes     String?
  extractedData   Json?
  declineReason   String?
  documentType    String?
  documentFrontUrl String?
  documentBackUrl  String?
  selfieUrl       String?
  shuftiReference String?
  shuftiEventType String?
  invitationToken String?
  completedAt     DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  org             ClientOrganization @relation(fields: [orgId], references: [id])
  telemetryEvents TelemetryEvent[]
}

enum VerificationType {
  KYC
  KYB
  KYI
}

enum VerificationStatus {
  STARTED
  PENDING_REVIEW
  APPROVED
  REJECTED
  ESCALATED
  EXPIRED
}

enum SentinelOutcome {
  PASS
  REVIEW
  REJECT
}

// ── Audit Log ────────────────────────────────────────────
model AuditLog {
  id          String             @id @default(cuid())
  logId       String             @unique @default(cuid())
  orgId       String
  eventType   String
  actorId     String?
  actorRole   String?
  targetType  String?
  targetId    String?
  before      Json?
  after       Json?
  ipAddress   String?
  userAgent   String?
  timestamp   DateTime           @default(now())
  org         ClientOrganization @relation(fields: [orgId], references: [id])
}

// ── Telemetry Event ──────────────────────────────────────
model TelemetryEvent {
  id             String        @id @default(cuid())
  eventId        String        @unique @default(cuid())
  eventType      String
  eventVersion   String        @default("1.0")
  orgId          String
  actorType      String
  actorId        String?
  sessionId      String?
  environment    String        @default("production")
  source         String
  traceId        String?
  properties     Json?
  context        Json?
  verificationId String?
  timestamp      DateTime      @default(now())
  verification   Verification? @relation(fields: [verificationId], references: [id])
}

// ── Client API Key ───────────────────────────────────────
model ClientAPIKey {
  id          String             @id @default(cuid())
  orgId       String
  name        String
  key         String             @unique
  isRevoked   Boolean            @default(false)
  lastUsedAt  DateTime?
  usageCount  Int                @default(0)
  errorCount  Int                @default(0)
  createdBy   String?
  createdAt   DateTime           @default(now())
  org         ClientOrganization @relation(fields: [orgId], references: [id])
}

// ── Webhook ──────────────────────────────────────────────
model ClientWebhook {
  id           String             @id @default(cuid())
  orgId        String
  url          String
  events       String[]
  isActive     Boolean            @default(true)
  secret       String
  retryCount   Int                @default(3)
  lastStatus   Int?
  lastDelivery DateTime?
  failCount    Int                @default(0)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  org          ClientOrganization @relation(fields: [orgId], references: [id])
}

// ── Report ───────────────────────────────────────────────
model Report {
  id          String             @id @default(cuid())
  orgId       String
  type        String
  format      String
  filters     Json?
  generatedBy String?
  fileUrl     String?
  status      String             @default("pending")
  createdAt   DateTime           @default(now())
  org         ClientOrganization @relation(fields: [orgId], references: [id])
}

// ── Alert Rule ───────────────────────────────────────────
model AlertRule {
  id          String             @id @default(cuid())
  orgId       String
  alertType   String
  threshold   Float
  severity    String
  channels    String[]
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  org         ClientOrganization @relation(fields: [orgId], references: [id])
}
